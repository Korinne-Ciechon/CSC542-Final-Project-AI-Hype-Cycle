    },
    {
      "cell_type": "code",
      "source": [
        "# Aggregate video level data to BI-WEEKLY window level data\n",
        "\n",
        "# Load — filter out rows where LLM had low confidence in transcripts/relevance of content to technology\n",
        "# Occurred in cases like Sora generated music, transcript is not relevant to SoraAI\n",
        "df_clean = pd.read_csv(DATASET1_FILE).copy()\n",
        "print(f\"Rows loaded: {len(df_clean)}\")\n",
        "\n",
        "df_clean = df_clean[df_clean['confidence'] >= 0.3].copy()\n",
        "print(f\"Rows after filtering out low quality (confidence) transcripts: {len(df_clean)}\")\n",
        "\n",
        "# Category mapping\n",
        "CATEGORY_MAP = {\n",
        "    '1': 'Film & Animation', '2': 'Autos & Vehicles', '10': 'Music',\n",
        "    '15': 'Pets & Animals', '17': 'Sports', '18': 'Short Movies',\n",
        "    '19': 'Travel & Events', '20': 'Gaming', '21': 'Videoblogging',\n",
        "    '22': 'People & Blogs', '23': 'Comedy', '24': 'Entertainment',\n",
        "    '25': 'News & Politics', '26': 'Howto & Style', '27': 'Education',\n",
        "    '28': 'Science & Technology', '29': 'Nonprofits & Activism',\n",
        "    '30': 'Movies', '31': 'Anime/Animation', '32': 'Action/Adventure',\n",
        "    '33': 'Classics', '34': 'Comedy', '35': 'Documentary',\n",
        "    '36': 'Drama', '37': 'Family', '38': 'Foreign', '39': 'Horror',\n",
        "    '40': 'Sci-Fi/Fantasy', '41': 'Thriller', '42': 'Shorts',\n",
        "    '43': 'Shows', '44': 'Trailers'\n",
        "}\n",
        "\n",
        "df_clean['category_label'] = df_clean['categoryId'].astype(str).map(CATEGORY_MAP)\n",
        "df_clean['like_ratio']     = df_clean['like_count'] / df_clean['view_count']\n",
        "df_clean['comment_ratio']  = df_clean['comment_count'] / df_clean['view_count']\n",
        "df_clean['is_sci_tech']    = (df_clean['category_label'] == 'Science & Technology').astype(int)\n",
        "\n",
        "# Aggregation helpers\n",
        "def mode_first(series):\n",
        "    mode = series.mode()\n",
        "    return mode.iloc[0] if len(mode) > 0 else None\n",
        "\n",
        "def topic_diversity(series):\n",
        "    return series.nunique() / 6\n",
        "\n",
        "def category_diversity(series):\n",
        "    return series.nunique() / len(CATEGORY_MAP)\n",
        "\n",
        "# Per-window aggregation\n",
        "agg = df_clean.groupby(['technology', 'window_number']).agg(\n",
        "    window_start_date     = ('window_start_date', 'first'),\n",
        "    window_end_date       = ('window_end_date', 'first'),\n",
        "    days_since_launch     = ('days_since_launch', 'first'),\n",
        "    video_count           = ('video_id', 'count'),\n",
        "    mean_sentiment        = ('sentiment', 'mean'),\n",
        "    median_sentiment      = ('sentiment', 'median'),\n",
        "    sentiment_std         = ('sentiment', 'std'),\n",
        "    proportion_positive   = ('sentiment', lambda x: (x > 0).mean()),\n",
        "    proportion_negative   = ('sentiment', lambda x: (x < 0).mean()),\n",
        "    mean_views            = ('view_count', 'mean'),\n",
        "    mean_hyperbole        = ('hyperbole', 'mean'),\n",
        "    mean_complexity       = ('complexity', 'mean'),\n",
        "    dominant_topic        = ('dominant_topic', mode_first),\n",
        "    topic_diversity       = ('dominant_topic', topic_diversity),\n",
        "    mean_duration         = ('duration_seconds', 'mean'),\n",
        "    mean_subscriber_count = ('channel_subscriber_count', 'mean'),\n",
        "    dominant_category     = ('category_label', mode_first),\n",
        "    category_diversity    = ('category_label', category_diversity),\n",
        "    prop_sci_tech         = ('is_sci_tech', 'mean'),\n",
        "    mean_like_ratio       = ('like_ratio', 'mean'),\n",
        "    mean_comment_ratio    = ('comment_ratio', 'mean'),\n",
        ").reset_index()\n",
        "\n",
        "# Sentiment slope\n",
        "def calc_slope(tech_df, current_window, n=5):\n",
        "    prior = tech_df[tech_df['window_number'] < current_window].tail(n)\n",
        "    if len(prior) < 3:\n",
        "        return None\n",
        "    slope, _, _, _, _ = stats.linregress(prior['window_number'], prior['mean_sentiment'])\n",
        "    return slope\n",
        "\n",
        "agg['sentiment_slope'] = [\n",
        "    calc_slope(agg[agg['technology'] == row['technology']], row['window_number'])\n",
        "    for _, row in agg.iterrows()\n",
        "]\n",
        "\n",
        "# Save aggregated dataset\n",
        "agg.to_csv(DATASET2_FILE, index=False)\n",
        "print(f\"\\nSaved — {len(agg)} windows, {len(agg.columns)} columns\")\n",
        "print(f\"Bi-weekly time windows per technology:\\n{agg.groupby('technology')['window_number'].count().to_string()}\")"
      ],
