          "text": [
            "Defined functions to extract semantic features.\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Find existing LLM features (from previous run) OR run extraction\n",
        "\n",
        "if os.path.exists(DATASET1_FILE):\n",
        "    print(f\"Found existing full file — loading\")\n",
        "    df_features = pd.read_csv(DATASET1_FILE)\n",
        "\n",
        "else:\n",
        "    print(\"No full file found — running extraction on all input files\")\n",
        "    dfs = []\n",
        "\n",
        "    for person, input_path in INPUT_FILES.items():\n",
        "        print(f\"\\n{person}: Running extraction on {input_path}\")\n",
        "        df = pd.read_csv(input_path)\n",
        "        # Filter out rows where all technologies scored \"zero\"; noisy videos where none of the technologies appeared at all in title, description, or transcript\n",
        "        # Occured in rare cases where creators may edit tags, for example, to include keywords like ChatGPT\n",
        "        df = df[~df['tech_scores'].apply(all_scores_zero)].reset_index(drop=True)\n",
        "        print(f\"  {len(df)} rows after filtering\")\n",
        "\n",
        "        df_out = df.copy()\n",
        "        for col in ['sentiment', 'hyperbole', 'complexity', 'audience', 'dominant_topic', 'confidence']:\n",
        "            df_out[col] = None\n",
        "\n",
        "        remaining = df_out[df_out['sentiment'].isna()].index.tolist()\n",
        "\n",
        "        try:\n",
        "            for count, idx in enumerate(remaining):\n",
        "                row = df_out.loc[idx]\n",
        "                print(f\"  [{count+1}/{len(remaining)}] {row['title'][:60]}\")\n",
        "                result = call_gemini(row)\n",
        "                if result:\n",
        "                    for col in ['sentiment', 'hyperbole', 'complexity', 'audience', 'dominant_topic', 'confidence']:\n",
        "                        df_out.at[idx, col] = result.get(col)\n",
        "                if (count + 1) % 10 == 0:\n",
        "                    print(f\"  Checkpoint at row {count+1}\")\n",
        "                time.sleep(4)\n",
        "\n",
        "            print(f\"  {person} complete\")\n",
        "            dfs.append(df_out)\n",
        "\n",
        "        except KeyboardInterrupt:\n",
        "            print(f\"\\n  Interrupted during {person}\")\n",
        "            dfs.append(df_out)\n",
        "            break\n",
        "\n",
        "    df_features = pd.concat(dfs, ignore_index=True)\n",
        "    df_features.to_csv(DATASET1_FILE, index=False)\n",
        "    print(f\"\\n  Saved — {len(df_features)} rows to {DATASET1_FILE}\")\n",
        "\n",
        "print(f\"\\nRows: {len(df_features)}\")\n",
        "print(f\"Null sentiments: {df_features['sentiment'].isna().sum()}\")\n",
        "print(f\"Technologies: {df_features['technology'].value_counts().to_dict()}\")"
      ],
      "metadata": {
        "colab": {
