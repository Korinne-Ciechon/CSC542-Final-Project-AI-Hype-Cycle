        "# Installing dependencies\n",
        "!pip install -q vaderSentiment scikit-learn youtube_transcript_api\n",
        "print('All packages installed.')"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Configuration\n",
        "import os\n",
        "import json\n",
        "import time\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "from google import genai\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "BASE_DIR = \"/content/drive/MyDrive/Colab Notebooks/CSC542Project/data\"\n",
        "\n",
        "# Input files (generated from 01_load_data_person[X].ipynb)\n",
        "# Files with data per YouTube video (up to top 15 videos per each of 39 bi-weekly time windows)\n",
        "# Each file has different AI technologies, since we split up querying for API usage efficiency\n",
        "INPUT_FILES = {\n",
        "    \"P1\": f\"{BASE_DIR}/youtube_hype_P1.csv\",\n",
        "    \"P2\": f\"{BASE_DIR}/youtube_hype_P2.csv\",\n",
        "    \"P3\": f\"{BASE_DIR}/youtube_hype_P3.csv\",\n",
        "}\n",
        "\n",
        "# Output files\n",
        "os.makedirs(f\"{BASE_DIR}\", exist_ok=True)\n",
        "DATASET1_FILE = f\"{BASE_DIR}/youtube_hype_all_llm_features.csv\"\n",
        "DATASET2_FILE = f\"{BASE_DIR}/youtube_hype_all_aggregated.csv\"\n",
        "\n",
        "# Gemini 2.5 flash lite API to get semantic features\n",
        "GEMINI_API_KEY = \"redacted"\n",
        "GEMINI_MODEL   = \"gemini-2.5-flash-lite\"\n",
        "\n",
        "# Parameters\n",
        "N_SLOPE_WINDOW = 5\n",
        "MIN_TECH_SCORE = 1 # Tech score comes from 'assign_primary_technology' in script 1, will use to filter\n",
        "\n",
        "print(f\"Config loaded\")\n",
        "print(f\"  Dataset 1 : {DATASET1_FILE}\")\n",
        "print(f\"  Dataset 2 : {DATASET2_FILE}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "VB_qZ3dOUXxp",
        "outputId": "70d71349-d09a-4e5c-abc0-86883a4c62ee"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n",
            "Config loaded\n",
            "  Dataset 1 : /content/drive/MyDrive/Colab Notebooks/CSC542Project/data/youtube_hype_all_llm_features.csv\n",
            "  Dataset 2 : /content/drive/MyDrive/Colab Notebooks/CSC542Project/data/youtube_hype_all_aggregated_weekly.csv\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Helper functions to call Gemini API to extract semantic features from video title, description, transcript\n",
        "client = genai.Client(api_key=GEMINI_API_KEY)\n",
        "\n",
        "def all_scores_zero(tech_scores_str):\n",
        "    try:\n",
        "        scores = json.loads(tech_scores_str)\n",
        "        return all(v == 0 for v in scores.values())\n",
        "    except:\n",
        "        return False\n",
        "\n",
        "def build_prompt(row):\n",
        "    title       = row.get('title', '') or ''\n",
        "    description = str(row.get('description', '') or '')[:1000]\n",
        "    transcript  = str(row.get('transcript_text', '') or '')\n",
        "    content     = f\"TITLE: {title}\\n\\nDESCRIPTION: {description}\\n\\nTRANSCRIPT: {transcript}\"\n",
        "    prompt = f\"\"\"You are a research assistant analyzing YouTube videos about AI technology.\n",
        "\n",
        "Analyze the content below and return ONLY a JSON object, no other text.\n",
        "\n",
        "SCORING:\n",
        "\n",
        "- sentiment (-1.0 to 1.0): Overall tone toward the AI technology.\n",
        "  -1.0 = catastrophic, alarmist, or complete failure framing\n",
        "   0.0 = neutral, factual, balanced\n",
        "   1.0 = utopian, euphoric, overwhelmingly positive\n",
        "  Note: technical terms like \"hallucination\", \"fine-tuning\", \"token\" are neutral vocabulary.\n",
        "\n",
        "- hyperbole (0.0 to 1.0): Degree of language exaggeration, regardless of sentiment.\n",
        "   0.0 = measured, academic, matter-of-fact\n",
        "   0.5 = noticeable enthusiasm or alarm\n",
        "   1.0 = maximum exaggeration (\"MIND-BLOWING\", \"RIP Google\", \"changes EVERYTHING FOREVER\")\n",
        "\n",
        "- complexity (0.0 to 1.0): Technical depth of the content.\n",
        "   0.0 = general public, analogies only\n",
        "   0.3 = informed enthusiast\n",
        "   0.6 = practitioner\n",
        "   1.0 = expert (transformer internals, fine-tuning, RAG pipelines, benchmarks)\n",
        "\n",
        "- audience: Exactly one of:\n",
        "  \"General Public\" | \"Developers/Technical\" | \"Business/Enterprise\"\n",
        "\n",
        "- dominant_topic: Exactly one of:\n",
        "  \"Enthusiast/Reaction\" | \"Technical Tutorial\" | \"Ethics/Safety\" |\n",
        "  \"News/Analysis\" | \"Critical/Evaluative\" | \"Practical Application\"\n",
        "\n",
        "- confidence (0.0 to 1.0):\n",
        "   1.0 = clear, long transcript directly about the technology\n",
        "   0.0 = not meaningfully about the technology or transcript too short/garbled\n",
        "\n",
        "Return exactly:\n",
        "{{\"sentiment\": float, \"hyperbole\": float, \"complexity\": float, \"audience\": string, \"dominant_topic\": string, \"confidence\": float}}\n",
        "\n",
        "CONTENT:\n",
        "{content}\"\"\"\n",
        "    return prompt\n",
        "\n",
        "def call_gemini(row):\n",
        "    prompt = build_prompt(row)\n",
        "    try:\n",
        "        response = client.models.generate_content(\n",
        "            model=GEMINI_MODEL,\n",
        "            contents=prompt,\n",
        "            config={\"temperature\": 0}\n",
        "        )\n",
        "        text = response.text.strip().replace('```json', '').replace('```', '').strip()\n",
        "        return json.loads(text)\n",
        "    except Exception as e:\n",
        "        print(f\"  Error: {e}\")\n",
        "        return None\n",
        "\n",
        "print(\"Defined functions to extract semantic features.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "zwLg-wk_Uhld",
