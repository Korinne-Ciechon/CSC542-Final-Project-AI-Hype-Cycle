          "text": [
            "Found existing full file — loading\n",
            "\n",
            "Rows: 1303\n",
            "Null sentiments: 8\n",
            "Technologies: {'Gemini': 401, 'ChatGPT': 359, 'GPT-4': 262, 'GitHub_Copilot': 162, 'SoraAI': 119}\n"
          ]
        }
